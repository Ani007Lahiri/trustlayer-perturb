    "eqtl_alone": "CD4/Treg cis-eQTL n_sig (continuous, function-blind)",
    "random": "uniform random, 2000 permutations"
  },
  "metrics": "AUROC (primary) + average precision; bootstrap 95% CI (2000 resamples) on gate AUROC and on gate-minus-best-baseline advantage; label-permutation p (2000) for gate beats best baseline.",
  "decision_rule": {
    "CLEAN_WIN": "gate AUROC > best baseline AND gate-minus-best-baseline 95% CI excludes 0 (lower bound > 0)",
    "STILL_MARGINAL": "gate AUROC > best baseline but advantage CI includes 0",
    "WEAKENED": "gate AUROC > best baseline but by less than iter4 AND CI includes 0 (advantage shrank vs iter4's [-0.003,0.369])",
    "NEGATIVE": "gate AUROC <= best baseline",
    "UNDERPOWERED": "n_external_positives < 12"
